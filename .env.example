# Breeze API Key (recommended - get one at https://breezemcp.xyz)
# BREEZE_API_KEY=bz_your_api_key

# Or use direct proxy credentials (self-hosted mode)
# BREEZE_PROXY_USER=your_proxy_username
# BREEZE_PROXY_PASS=your_proxy_password
# BREEZE_PROXY_HOST=p1.bytesflows.com
# BREEZE_PROXY_PORT=8001

# Optional: Custom gateway URL
# BREEZE_GATEWAY_URL=https://api.breezemcp.xyz/v1